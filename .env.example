# =============================================================
# .env.example — copy to .env and adjust as needed.
# These environment variables override both the defaults and config.yaml.
# Docker Compose reads .env automatically.
# =============================================================

# --- paths ---
DDOS_DATASET_PATH=data/BCCC-cPacket-Cloud-DDoS-2024
DDOS_MODEL_DIR=models
DDOS_LOG_DIR=logs
DDOS_OUTPUT_DIR=ddos_results

# --- training / data ---
DDOS_SAMPLE_FRAC=1.0

# --- API server ---
DDOS_API_HOST=0.0.0.0
DDOS_API_PORT=8000
DDOS_ALERT_THRESHOLD=0.75
DDOS_LOG_LEVEL=INFO

# --- simulation ---
DDOS_API_URL=http://localhost:8000
DDOS_SIM_SPEED=15
DDOS_SIM_DURATION=120
